{
	"name": "oh-my-snow",
	"version": "0.2.0",
	"description": "Oh-My-Snow — Autonomous orchestration plugin for Snow CLI",
	"type": "module",
	"main": "dist/mcp-server.js",
	"bin": {
		"oms": "dist/installer.js"
	},
	"files": [
		"dist",
		"assets",
		"hooks",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"start": "node dist/mcp-server.js",
		"test": "node test/test-hooks.mjs && node test/test-v2-hooks.mjs && node test/test-mcp.mjs && node test/test-skill-evolution.mjs && node test/test-review-fixes.mjs",
		"prepublishOnly": "npm run build && npm test"
	},
	"keywords": [
		"snow-cli",
		"mcp",
		"orchestration",
		"autonomous",
		"ai",
		"plugin"
	],
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0",
		"@types/node": "^22.10.0"
	}
}
